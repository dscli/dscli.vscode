# Ignore development files
.vscode/**
.git/**
node_modules/**
src/**
*.ts
!*.d.ts
tsconfig.json
eslint.config.js

# Include only essential out/ files (exclude tests)
!out/extension.js
!out/ui/**
!out/services/**
!out/utils/**
# Do NOT include out/__tests__/**

# Ignore config files at root
jest.config.cjs
jest.setup.cjs

# Ignore docs
docs/**
.dscli/**

# Ignore temp/log files
*.log
*.tmp
*.swp
.DS_Store
Thumbs.db

# Explicitly exclude test files (override any includes)
out/__tests__/**
